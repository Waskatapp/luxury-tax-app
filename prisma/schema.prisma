// WAT framework: see CLAUDE.md section 7. Every tenant-owned model has storeId + @@index([storeId]).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums ----

enum UserRole {
  STORE_OWNER
  STORE_ADMIN
  VIEW_ONLY
}

enum PendingActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum MemoryCategory {
  BRAND_VOICE
  PRICING_RULES
  PRODUCT_RULES
  CUSTOMER_RULES
  STORE_CONTEXT
  OPERATOR_PREFS
  // V2.0 — added ahead of Phase 2.1 (CEO Brain) so the migration that
  // wires guardrails into the prompt doesn't have to also add the enum
  // value. Stores load-bearing rules the CEO must honor and warn about
  // before violating (e.g. "never discount under 10%", "always test on
  // draft products first", "Q2 goal: 20% revenue growth").
  STRATEGIC_GUARDRAILS
}

// ---- Shopify session storage (managed by @shopify/shopify-app-session-storage-prisma; do not alter fields) ----

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ---- Tenant root ----

model Store {
  id            String    @id @default(cuid())
  shopDomain    String    @unique
  accessToken   String
  scopes        String?
  ownerEmail    String?
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  updatedAt     DateTime  @updatedAt

  conversations    Conversation[]
  pendingActions   PendingAction[]
  storeMemories    StoreMemory[]
  auditLogs        AuditLog[]
  suggestionEvents SuggestionEvent[]
  turnSignals      TurnSignal[]
  plans            Plan[]
  artifacts        Artifact[]
  actionFollowups  ActionFollowup[]
  insights         Insight[]
}

// ---- Chat thread per store+user ----

model Conversation {
  id        String   @id @default(cuid())
  storeId   String
  userId    String
  userRole  UserRole
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages        Message[]
  turnSignals     TurnSignal[]
  plans           Plan[]
  artifacts       Artifact[]
  actionFollowups ActionFollowup[]

  @@index([storeId])
  @@index([storeId, userId])
}

// content holds the exact Anthropic ContentBlock[] array — no translation (CLAUDE.md rule 3).
//
// searchText is a denormalized lowercased projection of content[].text used by
// the V1.7 conversation search (`app/lib/conversations/search.server.ts`).
// Null on tool_use-only or tool_result-only rows where there is no
// user-visible text. Populated by extractSearchText() at insert time.
model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        Json
  model          String?
  usage          Json?
  searchText     String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  turnSignal   TurnSignal?

  @@index([conversationId])
}

// toolCallId @unique prevents double-execution (CLAUDE.md rule 10, section 7).
model PendingAction {
  id             String              @id @default(cuid())
  storeId        String
  conversationId String
  toolCallId     String              @unique
  toolName       String
  toolInput      Json
  status         PendingActionStatus @default(PENDING)
  beforeSnapshot Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([conversationId])
  @@index([status])
}

// Persistent brand facts. Upsert-safe via [storeId, key] unique.
model StoreMemory {
  id        String         @id @default(cuid())
  storeId   String
  category  MemoryCategory
  key       String
  value     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, key])
  @@index([storeId])
  @@index([storeId, category])
}

// Welcome-screen prompt-suggestion telemetry. One row per impression-batch
// (3-4 rows per page load, same createdAt) and one row per click. Used today
// only for short-term session de-dupe; future phase computes CTR per
// templateId for ranking. eventType is String not enum so we can extend with
// "refresh"/"dismiss" without a schema migration.
model SuggestionEvent {
  id             String   @id @default(cuid())
  storeId        String
  userId         String
  templateId     String
  slotPosition   Int
  eventType      String
  conversationId String?
  createdAt      DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, templateId, eventType])
  @@index([storeId, createdAt])
}

// Immutable. before + after snapshots. Never deleted.
model AuditLog {
  id        String   @id @default(cuid())
  storeId   String
  userId    String?
  action    String
  toolName  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([storeId, createdAt])
}

// V2.3 — Plan-First. One row per `propose_plan` tool call. The CEO uses
// this when a request takes more than one write or crosses departments
// (e.g. "audit my catalog and lower any overpriced items"). The merchant
// approves the plan as a whole; each step's write still goes through the
// regular ApprovalCard flow.
//
// `toolCallId @unique` mirrors PendingAction: the CEO's tool_use block
// in the assistant Message links to the Plan row by this id, and dedupes
// against retries.
//
// `status` is a String not an enum so we can extend (e.g. PARTIALLY_EXECUTED)
// without a schema migration. Lifecycle: PENDING → APPROVED | REJECTED.
// EXECUTING / COMPLETED / FAILED states are reserved for if/when we ever
// auto-execute the steps after approval (today the CEO drives execution
// manually via the agent loop after seeing the synthesized tool_result).
model Plan {
  id             String   @id @default(cuid())
  storeId        String
  conversationId String
  toolCallId     String   @unique
  summary        String
  steps          Json // PlanStep[] — see app/lib/agent/plans.server.ts
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([conversationId])
  @@index([storeId, status])
}

// V2.2 — Learning Foundation. One row per assistant turn that completes
// (the SSE `done` event fires). Records the outcome (approved / rejected /
// clarified / informational, with rephrased / abandoned re-classified
// after the fact) plus latency and metadata. Phase 2.6 (Reflection) mines
// this for prompt-block tweaks; Phase 2.4 (tiered model routing) reads
// `modelUsed` for cost/quality analysis.
//
// `outcome` is a String not an enum so we can extend the taxonomy
// without a schema migration as we learn what categories matter.
model TurnSignal {
  id               String   @id @default(cuid())
  storeId          String
  conversationId   String
  messageId        String   @unique // 1:1 with the assistant Message
  outcome          String // approved | rejected | clarified | rephrased | abandoned | informational
  toolCalls        Int      @default(0) // # of tool_use blocks emitted
  hadWriteTool     Boolean  @default(false)
  hadClarification Boolean  @default(false)
  hadPlan          Boolean  @default(false) // Phase 2.3
  latencyMs        Int? // wall-clock from request entry to SSE done
  modelUsed        String? // "gemini-2.5-flash" | "gemini-2.5-flash-lite"
  ceoConfidence    Float? // 0–1, populated by Phase 2.6
  createdAt        DateTime @default(now())

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@index([storeId, outcome])
  @@index([conversationId])
}

// V2.5 — Artifacts Canvas. The CEO's editable buffer for prose drafts
// (product descriptions today; discount configs / promo copy later). When
// the CEO calls `propose_artifact`, an Artifact row is created in DRAFT
// status and the merchant edits it in the side panel. When approved, the
// content is funneled through the regular write tool's PendingAction flow
// (created on the fly with the latest edited content) so AuditLog and the
// "every Shopify write requires approval" rule both still hold.
//
// `toolCallId @unique` links to the propose_artifact tool_use block in the
// assistant Message (mirrors PendingAction / Plan).
//
// `content` shape varies by `kind`:
//   - "description": { productId, productTitle, html }
//
// `status` is a String not an enum so we can extend (e.g. SUPERSEDED if the
// CEO drafts a new version) without a schema migration. Lifecycle:
// DRAFT → APPROVED | REJECTED | DISCARDED.
model Artifact {
  id             String   @id @default(cuid())
  storeId        String
  conversationId String
  messageId      String?
  toolCallId     String   @unique
  kind           String
  content        Json
  status         String   @default("DRAFT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([storeId, status])
}

// V3.1 — Phase 3 Autonomous Reasoning Loop. One row per outcome-bearing
// write where the CEO commits to "I'll check this later." The CEO writes
// `evaluationCriteria` per action (min_sessions / min_days / max_days)
// based on the product's traffic and the change's magnitude — NOT a fixed
// schedule. The offline evaluator (GitHub Actions cron) picks rows with
// status=PENDING and dueAt<=now, runs significance math, and writes an
// Insight.
//
// `status` is a String not an enum so we can extend the lifecycle without
// a migration. Lifecycle: PENDING → EVALUATED | ABANDONED.
// ABANDONED = max_days elapsed without enough data to evaluate; the
// matching Insight has verdict=insufficient_data.
//
// `metric` is also String — extensible vocabulary
// (conversion_rate, revenue, sessions, units_sold, aov, …).
//
// conversationId / auditLogId / toolCallId are all optional: the CEO can
// queue a followup without a corresponding write (e.g. "check overall
// store conversion in 2 weeks"). insightId is set on evaluation; the
// reverse pointer (Insight.followupId) is also @unique so this is a
// logical 1:1 — modeled as plain string columns to avoid Prisma circular
// relation complexity.
model ActionFollowup {
  id                 String    @id @default(cuid())
  storeId            String
  conversationId     String?
  auditLogId         String?
  toolCallId         String?
  productId          String?
  metric             String
  hypothesis         String
  expectedDirection  String
  expectedEffectPct  Float?
  baselineSnapshot   Json
  evaluationCriteria Json
  status             String    @default("PENDING")
  dueAt              DateTime
  abandonAt          DateTime
  evaluatedAt        DateTime?
  insightId          String?
  createdAt          DateTime  @default(now())

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([storeId, status, dueAt])
  @@index([conversationId])
}

// V3.1 — Phase 3 Autonomous Reasoning Loop. The output of the offline
// evaluator. One row per evaluated followup, plus rows distilled from
// patterns in 4.4 (lessons), memory hygiene anomalies (6.4), and themes
// (5.4). Surfaced into the next conversation's CEO Observations slot,
// rate-limited to 2 per day per store.
//
// `category` is String for extensibility:
// "outcome_postmortem" | "lesson" | "anomaly" | "pattern" | "theme".
// `verdict` is String for the post-mortem taxonomy:
// "improved" | "worsened" | "inconclusive" | "insufficient_data".
// Default verdict is `inconclusive` (the math, not the LLM, decides
// when to flip — see app/lib/agent/evaluator.server.ts).
//
// `confidence` is the evaluator's confidence in the verdict (0–1).
// `significanceP` is the p-value if a significance test ran (null for
// non-postmortem categories like lessons or themes).
//
// `surfacedAt` populated when the Insight is woven into a conversation
// opening; daily rate limit reads this to enforce ≤2 unique surfaces per
// (storeId, day). `dismissedAt` populated when the merchant explicitly
// dismisses from the settings UI; dismissed Insights never surface again.
model Insight {
  id            String    @id @default(cuid())
  storeId       String
  followupId    String?   @unique
  category      String
  title         String
  body          String
  verdict       String
  confidence    Float
  significanceP Float?
  surfacedAt    DateTime?
  dismissedAt   DateTime?
  createdAt     DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, surfacedAt])
  @@index([storeId, createdAt])
}
