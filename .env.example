# Shopify app credentials (from Partner dashboard > App > Client credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://luxury-tax-app-production.up.railway.app
SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders,read_discounts,write_discounts

# PostgreSQL connection string (Railway auto-injects this in production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini API key (from aistudio.google.com)
GEMINI_API_KEY=

# 32-byte hex for AES-256-GCM encryption of Shopify access tokens at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Random string for session signing. Generate with: openssl rand -hex 32
SESSION_SECRET=
